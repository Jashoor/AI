COUPON_PREFIXES = ["FOOD", "SAVE", "MEAL", "TASTY", "CRAVE", "YUM", "BITE", "FEAST"]


def gen_coupons(n: int) -> list[Coupon]:
    coupons = []
    now = datetime.utcnow()
    for i in range(n):
        is_percent = random.random() > 0.5
        prefix = COUPON_PREFIXES[i % len(COUPON_PREFIXES)]
        coupons.append(
            Coupon(
                code=f"{prefix}{i:04d}",
                description=random.choice(...),
                ...
            )
        )
    return coupons
